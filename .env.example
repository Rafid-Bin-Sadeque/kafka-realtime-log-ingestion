# Copy this file to .env and fill in your values
# The docker-compose.yml Postgres service will use POSTGRES_USER/PASSWORD/DB below

# Kafka — default matches docker-compose.yml
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Postgres — matches the docker-compose postgres service
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PASSWORD=changeme

# Schema used for the learning project tables (created automatically by db_setup.py)
POSTGRES_SCHEMA=kafka_learn

# Optional: Discord webhook for EOD notifications (leave blank to disable)
DISCORD_WEBHOOK_URL=
